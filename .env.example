# Keel environment. Copy to .env.local and fill in. Never commit real secrets.

# SoSoValue OpenAPI — the brain (ETF flows + news). Required for live signals.
SOSOVALUE_API_KEY=
# Optional base-url / rate override (defaults baked into the client).
SOSOVALUE_API_BASE=
SOSOVALUE_RATE_LIMIT_PER_MIN=

# SoDEX — data reads vs order execution are split on purpose.
# Market data reads live from mainnet; order signing/execution is sandboxed on testnet.
SODEX_DATA_NETWORK=mainnet
SODEX_NETWORK=testnet
SODEX_API_BASE=

# AI narration (grounded only; every financial number is computed in code, never by the model).
# OpenAI-compatible endpoint. Deterministic fallback renders if this is unset or slow.
KEEL_AI_API_KEY=
KEEL_AI_API_BASE=
KEEL_AI_MODEL=

# Durable history (funding/flow snapshots + accumulation). Vercel Blob token.
BLOB_READ_WRITE_TOKEN=

# Protects the snapshot cron endpoint.
CRON_SECRET=

# ValueChain RPC for the injected wallet (connect + EIP-712 signing need no live RPC).
NEXT_PUBLIC_VALUECHAIN_RPC=
